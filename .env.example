# Docker Compose host ports
API_PORT=8080
WEB_PORT=3000
POSTGRES_PORT=5432
QDRANT_PORT=6333
FAKE_PROVIDER_PORT=8787

# Backend server configuration
AE_SERVER_HOST=127.0.0.1
AE_SERVER_PORT=8080
AE_DATA_DIR=./data
AE_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Postgres / pgvector
POSTGRES_DB=aeon_echoes
POSTGRES_USER=aeon
POSTGRES_PASSWORD=aeon_dev_password
AE_POSTGRES_DSN=postgres://aeon:aeon_dev_password@127.0.0.1:5432/aeon_echoes?sslmode=disable

# Qdrant
AE_QDRANT_URL=http://127.0.0.1:6333
AE_QDRANT_API_KEY=

# Static Web build/runtime
# Docker / nginx 部署默认走同源 /api，由 web 容器反代到 app 容器。
WEB_PUBLIC_API_BASE=/api

# Provider selection
AI_PROVIDER=fake
AI_PROVIDER_BASE_URL=http://127.0.0.1:8787

# Fake provider endpoints
FAKE_PROVIDER_HOST=0.0.0.0
OPENAI_BASE_URL=http://127.0.0.1:8787/v1
ANTHROPIC_BASE_URL=http://127.0.0.1:8787/anthropic
GEMINI_BASE_URL=http://127.0.0.1:8787/gemini

# Real provider placeholders. Keep empty in local development unless needed.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Go toolchain. Override if Go is on PATH or installed elsewhere.
GO_BIN=C:/Users/25945/sdk/go1.26.4/bin/go

# Go module proxy. Defaults use the official checksum database and proxy.
# For mainland China networks, GOPROXY=https://goproxy.cn,direct and GOSUMDB=sum.golang.google.cn are common alternatives.
GOPROXY=https://proxy.golang.org,direct
GOSUMDB=sum.golang.org

# Optional build network settings for Docker builds.
YARN_NPM_REGISTRY_SERVER=https://registry.npmjs.org
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres,qdrant,fake-provider,app,web
